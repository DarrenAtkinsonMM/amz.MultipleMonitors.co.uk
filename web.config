        <rule name="Ultimate PC Series Blog" stopProcessing="true">
          <match url="^blog/the-ultimate-pc-series/" ignoreCase="true" />
          <action type="Redirect" url="https://www.multiplemonitors.co.uk/blog/the-extreme-pc-series/" redirectType="Permanent" />
        </rule>
        <rule name="Accessories Redirect" stopProcessing="true">
          <match url="^accessories/" ignoreCase="true" />
          <action type="Redirect" url="https://www.multiplemonitors.co.uk/" redirectType="Permanent" />
        </rule>
        <rule name="Rextron USB VGA Redirect" stopProcessing="true">
          <match url="^products/rextron-usb-vga/" ignoreCase="true" />
          <action type="Redirect" url="https://www.multiplemonitors.co.uk/" redirectType="Permanent" />
        </rule>
        <rule name="Contact Page Redirect" stopProcessing="true">
          <match url="^shop/pc/contact\.asp$" ignoreCase="true" />
          <action type="Redirect" url="https://www.multiplemonitors.co.uk/pages/contact-us/" redirectType="Permanent" />
        </rule>

        <!-- Trader PC: bundle with slug path - /products/trader-pc/{stand-slug}/{monitor-slug}/ -->
        <rule name="Trader PC Bundle Slug" stopProcessing="true">
          <match url="^products/trader-pc/([^/]+)/([^/]+)/?$" ignoreCase="true" />
          <action type="Rewrite" url="/shop/pc/viewPrd-TraderPC-bundle.asp?stand={R:1}&amp;monitor={R:2}" />
        </rule>

        <!-- Trader PC: legacy bundle querystring (sid present) - kept so old URLs reach the ASP page and 301 to the slug form -->
        <rule name="Trader PC Bundle" stopProcessing="true">
          <match url="^products/trader-pc/?$" ignoreCase="true" />
          <conditions>
            <add input="{QUERY_STRING}" pattern="(^|&amp;)sid=[^&amp;]+" />
          </conditions>
          <action type="Rewrite" url="/shop/pc/viewPrd-TraderPC-bundle.asp" appendQueryString="true" />
        </rule>

        <!-- Trader PC: standard product page (no bundle querystring) -->
        <rule name="Trader PC Product" stopProcessing="true">
          <match url="^products/trader-pc/?$" ignoreCase="true" />
          <action type="Rewrite" url="/shop/pc/viewPrd-TraderPC.asp" appendQueryString="true" />
        </rule>

        <!-- Products ReWrite (dynamic - must come after all specific product redirects) -->
        <rule name="Products Rewrite" stopProcessing="true">
          <match url="^products/([^/]+)" ignoreCase="true" />
          <action type="Rewrite" url="/shop/pc/viewPrdRouter.asp?slug={R:1}" appendQueryString="true" />
        </rule>

        <!-- Pages ReWrite -->
        <rule name="Pages Rewrite" stopProcessing="true">
          <match url="^pages/([^/]+)" ignoreCase="true" />
          <action type="Rewrite" url="/shop/pc/viewContent.asp?url={R:1}" appendQueryString="true" />
        </rule>

        <!-- Blog Category Rewrites (specific categories must come before the generic blog rewrite) -->
	<rule name="Blog Index With Slash" stopProcessing="true">
	  <match url="^blog/$" ignoreCase="true" />
	  <action type="Rewrite" url="/new-blog/default.asp?catid=999" appendQueryString="true" />
	</rule>
        <rule name="Blog Hardware Category" stopProcessing="true">
          <match url="^blog/hardware" ignoreCase="true" />
          <action type="Rewrite" url="/new-blog/default.asp?catid=0" appendQueryString="true" />
        </rule>
        <rule name="Blog Product Guides Category" stopProcessing="true">
          <match url="^blog/product-guides" ignoreCase="true" />
          <action type="Rewrite" url="/new-blog/default.asp?catid=1" appendQueryString="true" />
        </rule>
        <rule name="Blog Setup Guides Category" stopProcessing="true">
          <match url="^blog/setup-guides" ignoreCase="true" />
          <action type="Rewrite" url="/new-blog/default.asp?catid=2" appendQueryString="true" />
        </rule>
        <rule name="Blog Software Category" stopProcessing="true">
          <match url="^blog/software" ignoreCase="true" />
          <action type="Rewrite" url="/new-blog/default.asp?catid=3" appendQueryString="true" />
        </rule>
        <rule name="Blog Stands Category" stopProcessing="true">
          <match url="^blog/stands" ignoreCase="true" />
          <action type="Rewrite" url="/new-blog/default.asp?catid=4" appendQueryString="true" />
        </rule>
        <rule name="Blog Trading Category" stopProcessing="true">
          <match url="^blog/trading" ignoreCase="true" />
          <action type="Rewrite" url="/new-blog/default.asp?catid=5" appendQueryString="true" />
        </rule>
        <rule name="Blog Post Rewrite" stopProcessing="true">
          <match url="^blog/([^/]+)" ignoreCase="true" />
          <action type="Rewrite" url="/shop/pc/viewContent.asp?url={R:1}" appendQueryString="true" />
        </rule>
       <rule name="Blog No Slash Redirect" stopProcessing="true">
  	  <match url="^blog$" ignoreCase="true" />
  	  <action type="Redirect" url="https://www.multiplemonitors.co.uk/blog/" redirectType="Permanent" />
	</rule>

        <!-- Payment ReWrite -->
        <rule name="Payment Rewrite" stopProcessing="true">
          <match url="^pay/([^/]+)/([^/]+)" ignoreCase="true" />
          <action type="Redirect" url="/shop/pc/manpayForm.asp?amount={R:1}&amp;pay={R:2}" redirectType="Permanent" />
        </rule>

      </rules>
    </rewrite>
        <defaultDocument>
            <files>
                <remove value="default.aspx" />
                <remove value="iisstart.htm" />
                <remove value="index.html" />
                <remove value="index.htm" />
                <remove value="Default.htm" />
            </files>
        </defaultDocument>
        <httpErrors errorMode="Detailed" />
  </system.webServer>
</configuration>
