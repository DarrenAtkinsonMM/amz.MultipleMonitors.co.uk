<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="1073741824"/>
      </requestFiltering>
      <dynamicIpSecurity denyAction="Forbidden" enableProxyMode="true" enableLoggingOnlyMode="false">
        <denyByConcurrentRequests enabled="true" maxConcurrentRequests="20" />
        <denyByRequestRate enabled="true" maxRequests="300" requestIntervalInMilliseconds="5000" />
      </dynamicIpSecurity>
    </security>
    <rewrite>
      <rules>

        <!-- Security: Block Empty User-Agent (blocks bots with no UA string) -->
        <rule name="Block Empty User-Agent" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{HTTP_USER_AGENT}" pattern="^$" />
          </conditions>
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Access Denied" />
        </rule>
        <!-- Security: Block all .php requests (not an applicable technology) -->
        <rule name="Block PHP Requests" stopProcessing="true">
          <match url=".*\.php$" ignoreCase="true" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Access Denied" />
        </rule>
        <!-- Security: Block WordPress paths (not an applicable technology) -->
        <rule name="Block WordPress Paths" stopProcessing="true">
          <match url="^(wp-admin|wp-content|wp-includes|wp-login\.php|wp-cron\.php|wp-comments-post\.php|wp-trackback\.php|wp-blog-header\.php|wp-signup\.php|xmlrpc\.php)" ignoreCase="true" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Access Denied" />
        </rule>
        <!-- Security: Block common scanner paths (phpMyAdmin, cgi-bin, etc.) -->
        <rule name="Block Scanner Paths" stopProcessing="true">
          <match url="^(phpmyadmin|pma|adminer\.php|cgi-bin)" ignoreCase="true" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Access Denied" />
        </rule>
        <!-- Security: Block .env file access (credential harvesting prevention) -->
        <rule name="Block Environment Files" stopProcessing="true">
          <match url="(^|/)\.env" ignoreCase="true" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Access Denied" />
        </rule>
        <!-- Security: Block .git repository access (source code protection) -->
        <rule name="Block Git Repository Access" stopProcessing="true">
          <match url="(^|/)\.git" ignoreCase="true" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Access Denied" />
        </rule>
        <!-- Security: Block backup archive probing in site root -->
        <rule name="Block Backup Archive Probing" stopProcessing="true">
          <match url="^[^/]*\.(zip|tar\.gz|tar|gz|rar|7z|sql|bak)$" ignoreCase="true" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Access Denied" />
        </rule>

        <!-- Block tel: protocol links crawled as relative URLs -->
        <rule name="Block Tel Protocol Paths" stopProcessing="true">
          <match url="tel:" ignoreCase="true" />
          <action type="CustomResponse" statusCode="404" statusReason="Not Found" statusDescription="Not Found" />
        </rule>

        <!-- HTTPS and WWW Redirect -->
        <rule name="Redirect to HTTPS WWW" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAny">
            <add input="{HTTPS}" pattern="off" ignoreCase="true" />
            <add input="{HTTP_HOST}" pattern="^multiplemonitors\.co\.uk$" ignoreCase="true" />
          </conditions>
          <action type="Redirect" url="https://www.multiplemonitors.co.uk/{R:1}" redirectType="Permanent" />
        </rule>

        <!-- Custom Category Pages - Internal Rewrites (with trailing slash) -->
        <rule name="Computers Category" stopProcessing="true">
          <match url="^computers/$" ignoreCase="true" />
          <action type="Rewrite" url="/shop/pc/CUSTOMCAT-computers.asp" appendQueryString="true" />
        </rule>
        <rule name="Computers No Slash Redirect" stopProcessing="true">
          <match url="^computers$" ignoreCase="true" />
          <action type="Redirect" url="https://www.multiplemonitors.co.uk/computers/" redirectType="Permanent" />
        </rule>

        <rule name="Trading Computers Category" stopProcessing="true">
          <match url="^trading-computers/$" ignoreCase="true" />
          <action type="Rewrite" url="/shop/pc/CUSTOMCAT-tradingcomputers.asp" appendQueryString="true" />
        </rule>
        <rule name="Trading Computers No Slash Redirect" stopProcessing="true">
          <match url="^trading-computers$" ignoreCase="true" />
          <action type="Redirect" url="https://www.multiplemonitors.co.uk/trading-computers/" redirectType="Permanent" />
        </rule>

        <!-- Dual Monitor Bundles Redirects -->
        <rule name="Dual Monitor Bundles Slash Redirect" stopProcessing="true">
          <match url="^dual-monitor-bundles/" ignoreCase="true" />
          <action type="Redirect" url="/bundles/" redirectType="Permanent" />
        </rule>
        <rule name="Dual Monitor Bundles No Slash Redirect" stopProcessing="true">
