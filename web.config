        <!-- Bundles Categories -->
        <rule name="Bundles Category" stopProcessing="true">
          <match url="^bundles/$" ignoreCase="true" />
          <action type="Rewrite" url="/shop/pc/bundlebuilder.asp" appendQueryString="true" />
        </rule>
        <!-- Bundles slug deeplinks: /bundles/<stand>/<monitor>/<pc>/ - resolved to ids by bundlebuilder.asp via mmSlugDict -->
        <rule name="Bundles 3 Segments" stopProcessing="true">
          <match url="^bundles/([^/]+)/([^/]+)/([^/]+)/?$" ignoreCase="true" />
          <action type="Rewrite" url="/shop/pc/bundlebuilder.asp?stand={R:1}&amp;monitor={R:2}&amp;computer={R:3}" appendQueryString="true" />
        </rule>
        <rule name="Bundles 2 Segments" stopProcessing="true">
          <match url="^bundles/([^/]+)/([^/]+)/?$" ignoreCase="true" />
          <action type="Rewrite" url="/shop/pc/bundlebuilder.asp?stand={R:1}&amp;monitor={R:2}" appendQueryString="true" />
        </rule>
        <rule name="Bundles 1 Segment" stopProcessing="true">
          <match url="^bundles/([^/]+)/?$" ignoreCase="true" />
          <action type="Rewrite" url="/shop/pc/bundlebuilder.asp?stand={R:1}" appendQueryString="true" />
        </rule>
        <!-- Legacy bundle picker URLs - old 3-step flow is discontinued.
             Catches /bundles-2, /bundles-2/, /bundles-2/anything, all variants
             with or without querystrings, and 301s to the canonical /bundles/. -->
        <rule name="Bundles 2 Legacy Redirect" stopProcessing="true">
          <match url="^bundles-2($|/)" ignoreCase="true" />
          <action type="Redirect" url="/bundles/" redirectType="Permanent" appendQueryString="false" />
        </rule>
        <rule name="Bundles 3 Legacy Redirect" stopProcessing="true">
          <match url="^bundles-3($|/)" ignoreCase="true" />
          <action type="Redirect" url="/bundles/" redirectType="Permanent" appendQueryString="false" />
        </rule>
        <rule name="Bundles No Slash Redirect" stopProcessing="true">
